<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    app:cardCornerRadius="14dp" app:cardElevation="4dp"
    android:layout_marginHorizontal="4dp" android:layout_marginVertical="6dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Цветна лява колона с кръвната група -->
        <LinearLayout android:layout_width="72dp" android:layout_height="match_parent"
            android:id="@+id/bloodBadge"
            android:orientation="vertical" android:gravity="center"
            android:paddingVertical="16dp">
            <TextView android:id="@+id/tvBloodType"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="22sp" android:textStyle="bold" android:textColor="#FFFFFF"
                android:gravity="center"/>
            <TextView android:id="@+id/tvUnits"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="11sp" android:textColor="#FFCCCC"
                android:gravity="center" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Вертикален разделител -->
        <View android:layout_width="1dp" android:layout_height="match_parent"
            android:background="#E0E0E0"/>

        <!-- Дясна секция с информация -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical"
            android:padding="12dp">
            <TextView android:id="@+id/tvUrgency"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="12sp" android:textStyle="bold"
                android:layout_marginBottom="2dp"/>
            <TextView android:id="@+id/tvHospital"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="15sp" android:textStyle="bold"
                android:textColor="@color/text_primary" android:layout_marginBottom="2dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:id="@+id/tvCity"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="13sp" android:textColor="@color/text_secondary"/>
                <TextView android:id="@+id/tvDate"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="11sp" android:textColor="@color/text_secondary"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Стрелка вдясно -->
        <TextView android:layout_width="24dp" android:layout_height="match_parent"
            android:text="›" android:textSize="24sp"
            android:textColor="@color/colorPrimary" android:gravity="center"
            android:layout_marginEnd="8dp"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
